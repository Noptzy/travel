SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

DATABASE_URL=jdbc:mysql://localhost:53306/makeyour_jurney
DATABASE_USERNAME=root
DATABASE_PASSWORD=root

REDIS_HOST=localhost
REDIS_PORT=6379

USE_SEED_DATA=true

AI_PROVIDER=openrouter
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

APIFY_ENABLED=false
APIFY_TOKEN=
APIFY_BASE_URL=https://api.apify.com/v2
APIFY_TIMEOUT_SECONDS=300
APIFY_MAX_ITEMS_HOTELS=20
APIFY_MAX_ITEMS_ACTIVITIES=20
APIFY_MAX_REVIEWS=30
APIFY_CACHE_TTL_HOURS=24
APIFY_HOTEL_ACTOR_ID=hotels-scrapers/traveloka-hotel-scraper
APIFY_ACTIVITY_ACTOR_ID=stealth_mode/traveloka-activities-search-scraper
APIFY_REVIEW_ACTOR_ID=knagymate/traveloka-reviews-scraper

MAPS_ENABLED=false
MAPS_PROVIDER=openrouteservice
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org
MAPS_CACHE_TTL_HOURS=168
MAPS_DEFAULT_COUNTRY=ID

MOBILE_API_BASE_URL=http://localhost:8080/api/v1

JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7
PLAN_CACHE_TTL_MINUTES=15
